# Entirely gitignored stages (large, regenerable)
/raw/
/embeddings/
/midi/
/pretraining/
/checkpoints/
/references/

# Scores: generated piece JSONs are gitignored, titles.json and seed.sql are tracked
/scores/*.json
!/scores/titles.json

# Eval outputs (manifests/metadata tracked separately)
/evals/inference_cache/
/evals/traces/
/evals/youtube_amt/
/evals/skill_eval/*/audio/
/evals/skill_eval/*/results.json

review.html